# Copy to .env and adjust for local development.
# Docker Compose reads these automatically when present.

# Postgres (default matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://trialspine:trialspine@db:5432/trialspine

# Path inside the API container where open TMB tests are mounted (optional Track B)
TMB_REPO_PATH=/tmb

# Host path to a clone of https://github.com/manybrainsproject/TestMyBrainCodeRepo
# Used only when starting with docker-compose.tmb.yml (see README).
TMB_HOST_PATH=./vendor/TestMyBrainCodeRepo
